{
  "id": "/pegmemo/",
  "name": "PEG memo",
  "short_name": "PEG memo",
  "description": "モバイル向けテキストエディタ",
  "start_url": "/pegmemo/",
  "scope": "/pegmemo/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "/pegmemo/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pegmemo/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/pegmemo/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["text/*", ".html", ".htm", ".txt", ".js", ".css"]
        }
      ]
    }
  }
}